python

import sys
import glob

# === STL pretty printers ===
# Найти путь к pretty printers автоматически
paths = glob.glob('/usr/share/gcc*/python')
if not paths:
    paths = glob.glob('/usr/lib/gcc/*/*/python')

for p in paths:
    if p not in sys.path:
        sys.path.insert(0, p)
        print("found printers in",p)

from libstdcxx.v6.printers import register_libstdcxx_printers
register_libstdcxx_printers(None)
print("STL pretty printers loaded.")

end